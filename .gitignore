# macOS
.DS_Store
# Finder text-clipping artifacts (created by dragging selected text to Finder).
*.textClipping

# R
.Rhistory
.Rapp.history
.Rproj.user/
*.Rproj
# R's default graphics dump — harmless but noisy in diffs.
Rplots.pdf

# renv: commit the lockfile and activation script, ignore the machine-specific
# library cache (users restore it via renv::restore()).
renv/library/
renv/local/
renv/cellar/
renv/staging/
renv/python/

# yamapData tarball — 257 MB, over GitHub's 100 MB per-file limit.
# Users obtain it separately and place it at pipeline/data/ before running setup.R.
# If you want it in the repo, set up Git LFS and remove this line.
pipeline/data/yamapData_*.tar.gz

# Reference β-matrices for v2.0.0 projection — the CSVs are 845 MB / 345 MB
# and the compact .rds cache is still ~137 MB, all far over GitHub's 100 MB
# per-file limit. Distributed separately (Git LFS or download-on-first-use)
# — see goals_v4.md Phase 0. The .rds is regenerated from the CSV on first
# use by reference_projection.R. The small embedding .RData files and the
# metadata CSV in reference/ ARE committed.
reference/beta_*

# Pipeline run outputs (local, machine-specific)
runs/
*.log

# Release artifacts produced by scripts/build_release.sh
dist/

# Claude Code session state
.claude/

# Editor junk
.vscode/
.idea/
*.swp
